---
import { AUTHOR_NAME, LINKEDIN_URL, GITHUB_URL } from '../config'
import Link from './Link.astro'

const currentYear = new Date().getFullYear()

const footerLinks = [
  { href: LINKEDIN_URL, label: 'LinkedIn', external: true },
  { href: GITHUB_URL, label: 'GitHub', external: true },
]
---

<footer class="bg-surface-warm border-border text-text/80 border-t">
  <div class="container py-8 md:py-10">
    <div class="flex flex-col gap-6 text-base md:flex-row md:items-center md:justify-between">
      <div class="flex flex-col gap-2">
        <p class="text-text font-heading font-bold">{AUTHOR_NAME}</p>
        <p>Web accessibility · Frontend · Inclusive design</p>
      </div>

      <nav aria-label="Footer" class="md:self-end">
        <ul role="list" class="m-0 flex list-none flex-wrap gap-x-6 gap-y-2 p-0">
          {
            footerLinks.map((link) => (
              <li>
                <Link href={link.href} external={link.external}>
                  {link.label}
                </Link>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div class="bg-warm-gray/20 my-4 h-px w-full"></div>

    <div class="flex w-full flex-wrap justify-between gap-x-6 gap-y-2 text-sm">
      <p>© {currentYear} {AUTHOR_NAME}</p>
      <Link href="/accessibility-statement">Accessibility statement</Link>
    </div>
  </div>
</footer>
