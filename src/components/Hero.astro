---
import { Icon } from 'astro-icon/components'
import { LINKEDIN_URL } from '../config'
---

<div class="grid grid-cols-1 items-center gap-12 md:grid-cols-[3fr_2fr] md:px-10 md:py-30">
  <div>
    <a
      href="https://www.credly.com/badges/936c762c-4526-4e4d-9bcb-373acd127a48/public_url"
      target="_blank"
      aria-label="IAAP WAS certified, verify on Credly (opens in new tab)"
      class="bg-accent/10 text-accent hover:bg-accent/20 mb-6 inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm font-medium no-underline transition-colors"
      rel="noopener noreferrer"
    >
      <Icon name="lucide:badge-check" class="h-4 w-4" aria-hidden="true" />
      IAAP WAS certified
      <Icon name="lucide:arrow-up-right" class="h-4 w-4" aria-hidden="true" />
    </a>

    <h1 class="text-text mb-6 text-5xl leading-tight font-black tracking-tight md:text-6xl">
      Hey, I'm Patricija!
    </h1>

    <p class="text-text-muted mb-8 max-w-lg text-base leading-relaxed md:text-lg">
      I specialize in <b class="text-text font-semibold">web accessibility</b> and
      <b class="text-text font-semibold">frontend development</b>
      — with deep experience in
      <b class="text-text font-semibold">WCAG</b>,
      <b class="text-text font-semibold">assistive technology testing</b>, and
      <b class="text-text font-semibold">inclusive design.</b>
    </p>

    <div class="flex flex-wrap gap-4">
      <a
        href="/work"
        class="bg-text inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-semibold text-white no-underline transition-opacity hover:opacity-80"
      >
        View work
        <Icon name="lucide:arrow-right" class="h-4 w-4" aria-hidden="true" />
      </a>
      <a
        href={LINKEDIN_URL}
        class="border-text/20 text-text hover:text-accent hover:border-accent hover:bg-accent/10 inline-flex items-center gap-2 rounded-full border px-6 py-3 text-sm font-semibold no-underline transition-colors"
        target="_blank"
        aria-label="LinkedIn (opens in new tab)"
        rel="noopener noreferrer"
      >
        LinkedIn
        <Icon name="lucide:arrow-up-right" class="h-4 w-4" aria-hidden="true" />
      </a>
    </div>
  </div>

  <div class="hidden items-center justify-center md:flex">
    <div class="bg-border flex h-96 w-80 items-center justify-center rounded-2xl">
      <Icon name="lucide:user" class="text-text-muted h-24 w-24 opacity-30" aria-hidden="true" />
    </div>
  </div>
</div>
