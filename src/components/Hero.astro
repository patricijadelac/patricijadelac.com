---
import { Icon } from 'astro-icon/components'
import { LINKEDIN_URL } from '../config'
import LinkButton from './LinkButton.astro'
---

<div class="container">
  <div class="py-8 md:px-10 md:py-30 lg:max-w-240">
    <div class="mb-4 flex flex-wrap items-center gap-2">
      <h1 class="eyebrow md:text-base md:tracking-widest">
        Patricija Delač · Web accessibility specialist
      </h1>
      <p
        class="eyebrow bg-accent/10 flex items-center gap-2 rounded-2xl px-3 py-1 md:ml-2 md:text-base"
      >
        <Icon name="lucide:graduation-cap" class="h-5 w-5" aria-hidden="true" />
        IAAP WAS certified
      </p>
    </div>

    <h2 class="hero-title mb-6">Accessible isn't a feature. It's whether it works.</h2>

    <p class="hero-subtitle mb-8 md:max-w-160 md:text-2xl">
      I help teams build accessible products through audits, hands-on development, and
      knowledge-sharing.
    </p>

    <div class="flex flex-wrap gap-4">
      <LinkButton href="/work" label="View work" icon="lucide:arrow-right" />
      <LinkButton href={LINKEDIN_URL} label="LinkedIn" variant="secondary" external />
    </div>
  </div>
</div>
