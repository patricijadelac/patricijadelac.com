---
import { Icon } from 'astro-icon/components'

interface Props {
  href: string
  label: string
  variant?: 'primary' | 'secondary' | 'white' | 'ghost-white'
  icon?: string
  external?: boolean
  class?: string
}

const { href, label, variant = 'primary', icon, external = false, class: className } = Astro.props

const externalAttrs = external
  ? { target: '_blank', rel: 'noopener noreferrer', 'aria-label': `${label} (opens in new tab)` }
  : {}
---

<a
  href={href}
  class:list={[
    'btn',
    'inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-semibold no-underline transition-all hover:-translate-y-px hover:shadow-xl',
    variant === 'primary' && 'bg-text text-white transition-opacity',
    variant === 'secondary' && 'border-warm-gray border-2',
    variant === 'white' && 'text-accent bg-white',
    variant === 'ghost-white' && 'border-2 border-white/30 text-white hover:border-white/60',
    className,
  ]}
  {...externalAttrs}
>
  {label}
  {icon && <Icon name={icon} class="h-4 w-4" aria-hidden="true" />}
  {external && !icon && <Icon name="lucide:arrow-up-right" class="h-4 w-4" aria-hidden="true" />}
</a>
