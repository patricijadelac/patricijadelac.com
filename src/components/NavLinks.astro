---
import { Icon } from 'astro-icon/components'
import { LINKEDIN_URL } from '../config'

const currentPath = Astro.url.pathname
const navLinks = [
  { href: '/work', label: 'Work' },
  { href: '/methodology', label: 'Methodology' },
  { href: '/writing', label: 'Writing' },
  { href: '/about', label: 'About' },
]
---

{
  navLinks.map((link) => (
    <li>
      <a
        href={link.href}
        aria-current={currentPath === link.href ? 'page' : undefined}
        class="text-text hover:text-text-muted aria-[current=page]:text-accent text-sm no-underline transition-colors aria-[current=page]:font-semibold"
      >
        {link.label}
      </a>
    </li>
  ))
}

<li>
  <a
    href={LINKEDIN_URL}
    class="bg-text inline-flex items-center gap-1 rounded-full px-5 py-2 text-sm font-semibold text-white no-underline transition-opacity hover:opacity-85"
    target="_blank"
    aria-label="LinkedIn (opens in new tab)"
    rel="noopener noreferrer"
  >
    LinkedIn
    <Icon name="lucide:arrow-up-right" class="h-4 w-4" aria-hidden="true" />
  </a>
</li>
