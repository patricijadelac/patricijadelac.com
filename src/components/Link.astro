---
import { Icon } from 'astro-icon/components'

interface Props {
  href: string
  external?: boolean
  class?: string
}

const { href, external = false, class: className } = Astro.props

const externalAttrs = external ? { target: '_blank', rel: 'noopener noreferrer' } : {}
---

<a
  href={href}
  class:list={[external && 'text-accent inline-flex items-center gap-1', className]}
  {...externalAttrs}
>
  <slot />
  {
    external && (
      <>
        <span class="sr-only">(opens in new tab)</span>
        <Icon name="lucide:arrow-up-right" class="h-4 w-4" aria-hidden="true" />
      </>
    )
  }
</a>
