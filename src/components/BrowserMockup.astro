---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  url: string
  src?: ImageMetadata
  alt?: string
}

const { url, src, alt = 'Product screenshot' } = Astro.props
---

<div
  class="max-w-140 overflow-hidden rounded-xl border border-[#cdc5b5] bg-white"
  style="box-shadow: rgba(28, 24, 21, 0.35) 0px 18px 40px -18px;"
>
  <div
    class="flex h-9.5 items-center gap-2 border-b border-[#ddd8cc] bg-[#edeae3] px-3.5"
    aria-hidden="true"
  >
    <span class="h-2.75 w-2.75 rounded-full bg-[#e0655b]"></span>
    <span class="h-2.75 w-2.75 rounded-full bg-[#e6b14c]"></span>
    <span class="h-2.75 w-2.75 rounded-full bg-[#69b85c]"></span>
    <div
      class="ml-3.5 flex h-5 flex-1 items-center rounded-md border border-[#ddd8cc] bg-white px-2.5 text-[11px] text-[#9a9082]"
    >
      {url}
    </div>
  </div>

  {
    src ? (
      <Image src={src} alt={alt} class="w-full" />
    ) : (
      <div
        class="flex aspect-4/3 flex-col items-center justify-center gap-2 text-[#9a9082]"
        style="background: repeating-linear-gradient(45deg, rgb(244, 241, 234), rgb(244, 241, 234) 12px, rgb(239, 235, 226) 12px, rgb(239, 235, 226) 24px);"
      >
        <span class="text-[13px] font-bold tracking-widest uppercase">Product screenshot</span>
        <span class="text-[13px]">Add your screenshot here</span>
      </div>
    )
  }
</div>
