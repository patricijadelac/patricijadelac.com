---
import LinkButton from './LinkButton.astro'

interface Cta {
  href: string
  label: string
  external?: boolean
}

interface Props {
  heading: string
  description: string
  cta: Cta
  secondaryCta?: Cta
  eyebrow?: string
}

const { heading, description, cta, secondaryCta, eyebrow } = Astro.props
---

<section class="bg-accent px-8 py-24 text-center">
  {eyebrow && <p class="section-eyebrow mb-4 text-white/50">{eyebrow}</p>}
  <h2 class="mb-6 text-4xl font-bold tracking-tighter text-white md:text-6xl">{heading}</h2>
  <p class="mx-auto mb-10 max-w-lg text-lg leading-relaxed text-white/70">{description}</p>
  <div class="flex flex-wrap items-center justify-center gap-4">
    <LinkButton href={cta.href} label={cta.label} external={cta.external} variant="white" />
    {
      secondaryCta && (
        <LinkButton
          href={secondaryCta.href}
          label={secondaryCta.label}
          external={secondaryCta.external}
          variant="ghost-white"
        />
      )
    }
  </div>
</section>
